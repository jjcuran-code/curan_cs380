
// Fibonacci with for loop
var a = 0;
var b = 1;
print a;
print b;
for (var i = 2; i < 10; i = i + 1) {
	var next = a + b;
	print next;
	a = b;
	b = next;
}

// Fibonacci with while loop
var x = 0;
var y = 1;
print x;
print y;
var count = 2;
while (count < 10) {
	var next = x + y;
	print next;
	x = y;
	y = next;
	count = count + 1;
}
